/* ============================================================
   STEP 1 | บอร์ดยังไหวไหม? (RGB LED + Serial)
   ------------------------------------------------------------
   เป้าหมาย: อัปโหลดโค้ดลงบอร์ดได้ และเห็นข้อความใน Serial Monitor
   สิ่งใหม่ที่ได้เรียน: setup() / loop() / Serial / delay()
   ------------------------------------------------------------
   *** ตั้งค่า Arduino IDE (ตรวจให้ครบ ไม่งั้นเจอปัญหาแปลก ๆ) ***
     Board            = "ESP32S3 Dev Module"
     USB CDC On Boot  = Enabled      <-- ไม่เปิด = Serial Monitor เงียบสนิท!
     Flash Size       = 16MB (128Mb)
     PSRAM            = OPI PSRAM    <-- ไม่เปิด = เสียของ 8MB ที่ซื้อมา
   ------------------------------------------------------------
   *** บทเรียนจากหน้างานจริง ***
   บอร์ดนี้ "ไม่มี LED ธรรมดา" แต่มี RGB LED (WS2812) และอยู่ที่ GPIO48
   (พินเอาต์ทางการของ Espressif บอกว่า 38 แต่บอร์ดตัวนี้ใช้ 48)
   --> digitalWrite() ใช้กับ WS2812 ไม่ได้ ต้องใช้ neopixelWrite()
   ============================================================ */

#define RGB_PIN 48        // RGB LED บนบอร์ด (ถ้าไม่ติด ลองเปลี่ยนเป็น 38)
#define BRIGHT  10        // ความสว่าง 1-255 (10 = นวลตา, 60 = แยงตา!)

void setup() {
  Serial.begin(115200);
  delay(500);
  Serial.println("STEP 1: สวัสดี! บอร์ดทำงานแล้ว");
}

void loop() {
  neopixelWrite(RGB_PIN, 0, BRIGHT, 0);              // เขียว = ดิบ
  Serial.println("ไฟติด - เขียว (ดิบ)");
  delay(600);

  neopixelWrite(RGB_PIN, BRIGHT, BRIGHT * 0.7, 0);   // เหลือง = สุกพอดี
  Serial.println("ไฟติด - เหลือง (สุกพอดี)");
  delay(600);

  neopixelWrite(RGB_PIN, BRIGHT, BRIGHT * 0.2, 0);   // ส้ม = งอม
  Serial.println("ไฟติด - ส้ม (งอม)");
  delay(600);

  neopixelWrite(RGB_PIN, 0, 0, 0);                   // ดับ
  Serial.println("ไฟดับ");
  delay(600);
}

/* ------------------------------------------------------------
   ผลที่ควรได้: ไฟ RGB ไล่สี เขียว -> เหลือง -> ส้ม -> ดับ
                + Serial Monitor (115200) พิมพ์ข้อความตาม

   ลองเล่นดู:
   1) เปลี่ยน BRIGHT เป็น 60 --> แยงตาไหม? แล้วลด 5 --> ต่างกันแค่ไหน?
   2) เปลี่ยน delay(600) เป็น delay(100) --> เกิดอะไรขึ้น?

   คำถาม 1: setup() ทำงานกี่ครั้ง? loop() ทำงานกี่ครั้ง?
   คำถาม 2: ทำไม LED ตัวนี้ใช้ digitalWrite() ไม่ได้?
            (คำใบ้: WS2812 ต้อง "ส่งข้อมูล" บอกสี ไม่ใช่แค่ "จ่ายไฟ")
   ------------------------------------------------------------ */
