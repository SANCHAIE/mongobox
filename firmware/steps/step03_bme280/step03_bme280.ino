/* ============================================================
   STEP 3 | เซ็นเซอร์ตัวแรก: อุณหภูมิ + ความชื้น (BME280)
   ------------------------------------------------------------
   เป้าหมาย: อ่านค่าจากเซ็นเซอร์ตัวจริงตัวแรกให้ได้
   สิ่งใหม่ที่ได้เรียน: ไลบรารี / object / การอ่านค่าเป็นตัวเลข

   ไลบรารีที่ต้องติดตั้ง: Adafruit BME280 Library (+ Adafruit Unified Sensor)
   ============================================================ */

#include <Wire.h>
#include <Adafruit_Sensor.h>
#include <Adafruit_BME280.h>

#define I2C_SDA 8
#define I2C_SCL 9

Adafruit_BME280 bme;          // สร้าง "ตัวแทน" ของเซ็นเซอร์


/* === i2cAlive(): ตรวจว่ามีอุปกรณ์อยู่จริงไหม (เชื่อถือได้ 100%) ===
   *** บทเรียนสำคัญจากหน้างาน ***
   begin() ของบางไลบรารี (เช่น SSD1306) "โกหก" ได้ — คืนค่า true
   ทั้งที่ไม่ได้ต่อจอเลย! เพราะมันไม่เช็ก ACK จริง
   วิธีนี้เช็กที่ระดับฮาร์ดแวร์ --> โกหกไม่ได้ */
bool i2cAlive(uint8_t addr) {
  Wire.beginTransmission(addr);
  return (Wire.endTransmission() == 0);
}

void setup() {
  Serial.begin(115200);
  Wire.begin(I2C_SDA, I2C_SCL);
  Wire.setClock(50000);   // ลดเป็น 50kHz — ทนสายยาว/หลวมได้ดีกว่า 100kHz มาก
  delay(500);
  Serial.println("\nSTEP 3: อ่านอุณหภูมิและความชื้น");

  // *** เช็ก ACK จริงก่อน แล้วค่อย begin() — อย่าเชื่อ begin() อย่างเดียว ***
  if      (i2cAlive(0x76)) { bme.begin(0x76); Serial.println("[OK] BME280 ที่ 0x76"); }
  else if (i2cAlive(0x77)) { bme.begin(0x77); Serial.println("[OK] BME280 ที่ 0x77"); }
  else Serial.println("[X] ไม่พบ BME280 — เช็กสาย VCC/GND/SDA/SCL แล้วกลับไป STEP 2");
}

void loop() {
  float temp = bme.readTemperature();   // องศาเซลเซียส
  float hum  = bme.readHumidity();      // เปอร์เซ็นต์

  Serial.print("อุณหภูมิ: ");
  Serial.print(temp, 1);
  Serial.print(" C   ความชื้น: ");
  Serial.print(hum, 1);
  Serial.println(" %");

  delay(1000);
}

