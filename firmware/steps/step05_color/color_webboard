void setup() {
  Serial.begin(115200);
  pinMode(BTN_PIN, INPUT_PULLUP);
  Wire.begin(I2C_SDA, I2C_SCL);
  Wire.setClock(50000);
  delay(500);

  if (i2cAlive(0x29)) { gSensorOK = tcs.begin(); Serial.println("[OK] TCS34725"); }
  else Serial.println("[X] ไม่พบ TCS34725 (0x29) — เช็กสาย");

  // โหลดค่าคาลิเบรตเดิม
  prefs.begin("colorcal", false);
  calibrated = prefs.getBool("cal", false);
  if (calibrated) {
    wbR = prefs.getFloat("wbR", 1.0);
    wbG = prefs.getFloat("wbG", 1.0);
    wbB = prefs.getFloat("wbB", 1.0);
    Serial.println("[NVS] โหลดค่าคาลิเบรตเดิมแล้ว");
  } else {
    Serial.println("[!] ยังไม่เคยคาลิเบรต — จ่อกระดาษขาวแล้วกดปุ่ม BOOT (หรือกดบนมือถือ)");
  }

  WiFi.mode(WIFI_STA);
  WiFi.begin(WIFI_SSID, WIFI_PASS);
  Serial.print("กำลังเชื่อม WiFi");
  int t = 0;
  while (WiFi.status() != WL_CONNECTED && t < 20) { delay(500); Serial.print("."); t++; }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.print("\n[OK] เปิดมือถือเข้าเว็บนี้:  http://");
    Serial.println(WiFi.localIP());
  } else {
    Serial.println("\n[X] ต่อ WiFi ไม่ได้ — ต้องเป็น WiFi 2.4GHz เท่านั้น!");
  }

  server.on("/",      handleRoot);
  server.on("/data",  handleData);
  server.on("/calib", handleCalib);
  server.begin();

  Serial.println("\nR,G,B,HEX,Hue,Ripe");
}

void loop() {
  server.handleClient();

  // ปุ่ม BOOT บนบอร์ด = คาลิเบรต (ทางเลือกนอกจากกดบนมือถือ)
  static bool prev = HIGH;
  bool now = digitalRead(BTN_PIN);
  if (prev == HIGH && now == LOW) {
    delay(50);
    if (digitalRead(BTN_PIN) == LOW) calibrateWhite();
  }
  prev = now;

  static unsigned long last = 0;
  if (millis() - last < 200) return;
  last = millis();

  if (!gSensorOK) return;
  readColor();

  Serial.print(gR);       Serial.print(',');
  Serial.print(gG);       Serial.print(',');
  Serial.print(gB);       Serial.print(",#");
  if (gR < 16) Serial.print("0"); Serial.print(gR, HEX);
  if (gG < 16) Serial.print("0"); Serial.print(gG, HEX);
  if (gB < 16) Serial.print("0"); Serial.print(gB, HEX);
  Serial.print(',');
  Serial.print(gHue, 0);  Serial.print(',');
  Serial.println(gRipe);
}
