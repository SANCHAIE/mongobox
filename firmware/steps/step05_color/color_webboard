/* ============================================================================
   COLOR DASHBOARD — โชว์สีที่เซ็นเซอร์เห็น บนมือถือ
   ----------------------------------------------------------------------------
   - แถบสีจริงเต็มจอ + ค่า HEX + แถบ R/G/B + Hue + %ความสุก
   - กดคาลิเบรตสีขาวได้จากมือถือ (ไม่ต้องเอื้อมไปกดปุ่มบนบอร์ด)
   - ไฟ RGB บนบอร์ดโชว์สีเดียวกันไปด้วย
   ----------------------------------------------------------------------------
   Board = ESP32S3 Dev Module | USB CDC On Boot = Enabled | PSRAM = OPI
   ขา: SDA=8, SCL=9, RGB=48, ปุ่ม BOOT=0
   ** WiFi ต้องเป็น 2.4GHz เท่านั้น! ESP32 ต่อ 5GHz ไม่ได้ **
   ============================================================================ */

#include <WiFi.h>
#include <WebServer.h>
#include <Wire.h>
#include <Adafruit_TCS34725.h>
#include <Preferences.h>

const char* WIFI_SSID = "Maker_Club_BUU";      // <<< แก้
const char* WIFI_PASS = "maker1234";               // <<< แก้

#define I2C_SDA 8
#define I2C_SCL 9
#define RGB_PIN 48
#define BRIGHT  25
#define BTN_PIN 0

#define HUE_RAW  120.0      // เขียว = ดิบ
#define HUE_RIPE  55.0      // เหลือง = สุก

WebServer server(80);
Adafruit_TCS34725 tcs(TCS34725_INTEGRATIONTIME_154MS, TCS34725_GAIN_4X);
Preferences prefs;

// ค่าคาลิเบรตสีขาว (เก็บลง NVS — ปิดเครื่องแล้วไม่ต้องคาลิเบรตใหม่)
float wbR = 1.0, wbG = 1.0, wbB = 1.0;
bool  calibrated = false;

// ค่าที่วัดได้
int   gR = 0, gG = 0, gB = 0;     // 0-255
float gHue = 0;
int   gRipe = 0;
uint16_t gClear = 0;
bool  gSensorOK = false;

bool i2cAlive(uint8_t a) {
  Wire.beginTransmission(a);
  return (Wire.endTransmission() == 0);
}

uint8_t gamma8(float v) {
  if (v < 0) v = 0;
  if (v > 1) v = 1;
  return (uint8_t)(pow(v, 2.2) * BRIGHT + 0.5);
}

float rgbToHue(float r, float g, float b) {
  float mx = max(r, max(g, b)), mn = min(r, min(g, b)), d = mx - mn;
  if (d < 0.0001) return 0;
  float h;
  if      (mx == r) h = 60.0 * fmod(((g - b) / d), 6.0);
  else if (mx == g) h = 60.0 * (((b - r) / d) + 2.0);
  else              h = 60.0 * (((r - g) / d) + 4.0);
  if (h < 0) h += 360.0;
  return h;
}

// ---------- คาลิเบรตสีขาว ----------
void calibrateWhite() {
  uint16_t r, g, b, c;
  tcs.getRawData(&r, &g, &b, &c);
  if (c == 0) return;

  float rN = (float)r / c, gN = (float)g / c, bN = (float)b / c;
  // ตอนจ่อขาว R,G,B ควรเท่ากัน --> หาตัวคูณที่ทำให้เท่ากัน
  wbR = (rN > 0.001) ? (1.0 / 3.0) / rN : 1.0;
  wbG = (gN > 0.001) ? (1.0 / 3.0) / gN : 1.0;
  wbB = (bN > 0.001) ? (1.0 / 3.0) / bN : 1.0;
  calibrated = true;

  prefs.putFloat("wbR", wbR);
  prefs.putFloat("wbG", wbG);
  prefs.putFloat("wbB", wbB);
  prefs.putBool("cal", true);

  Serial.print(">>> คาลิเบรตสีขาวแล้ว  wb = ");
  Serial.print(wbR, 2); Serial.print(" / ");
  Serial.print(wbG, 2); Serial.print(" / ");
  Serial.println(wbB, 2);

  for (int i = 0; i < 2; i++) {
    neopixelWrite(RGB_PIN, BRIGHT, BRIGHT, BRIGHT); delay(120);
    neopixelWrite(RGB_PIN, 0, 0, 0);                delay(120);
  }
}

// ---------- อ่านสี ----------
void readColor() {
  uint16_t r, g, b, c;
  tcs.getRawData(&r, &g, &b, &c);
  gClear = c;

  float rN = 0, gN = 0, bN = 0;
  if (c > 0) { rN = (float)r / c; gN = (float)g / c; bN = (float)b / c; }

  float rC = rN * wbR, gC = gN * wbG, bC = bN * wbB;

  // ขยายให้เต็มช่วง (ตัวแรงสุด = 1.0) เพื่อให้สีสดชัด
  float mx = max(rC, max(gC, bC));
  if (mx > 0.001) { rC /= mx; gC /= mx; bC /= mx; }

  gR = (int)(rC * 255);
  gG = (int)(gC * 255);
  gB = (int)(bC * 255);

  gHue = rgbToHue(rC, gC, bC);

  float pct = (gHue - HUE_RIPE) / (HUE_RAW - HUE_RIPE) * 100.0;
  if (pct < 0) pct = 0;
  if (pct > 100) pct = 100;
  gRipe = 100 - (int)pct;

  // ไฟบนบอร์ดโชว์สีเดียวกัน (ผ่าน gamma)
  neopixelWrite(RGB_PIN, gamma8(rC), gamma8(gC), gamma8(bC));
}

// ---------- API ----------
void handleData() {
  char hex[8];
  sprintf(hex, "#%02X%02X%02X", gR, gG, gB);

  String j = "{";
  j += "\"hex\":\"" + String(hex) + "\",";
  j += "\"r\":"     + String(gR)  + ",";
  j += "\"g\":"     + String(gG)  + ",";
  j += "\"b\":"     + String(gB)  + ",";
  j += "\"hue\":"   + String(gHue, 0)  + ",";
  j += "\"ripe\":"  + String(gRipe)    + ",";
  j += "\"clear\":" + String(gClear)   + ",";
  j += "\"cal\":"   + String(calibrated ? "true" : "false") + ",";
  j += "\"ok\":"    + String(gSensorOK ? "true" : "false")  + "}";
  server.send(200, "application/json", j);
}

void handleCalib() {
  calibrateWhite();
  server.send(200, "text/plain", "ok");
}

