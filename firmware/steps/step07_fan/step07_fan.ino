/* ============================================================
   STEP 7 | สั่งงานโลกจริง: เปิด/ปิดพัดลม (ทรานซิสเตอร์)
   ------------------------------------------------------------
   เป้าหมาย: ใช้ขา GPIO ควบคุมอุปกรณ์ที่กินไฟมาก (ผ่านทรานซิสเตอร์)
   สิ่งใหม่ที่ได้เรียน: output / ทรานซิสเตอร์เป็นสวิตช์ / ทำไมต้องมีไดโอด

   ** ห้ามต่อพัดลมเข้า GPIO ตรง ๆ เด็ดขาด! GPIO จ่ายไฟได้น้อยมาก **
   ** พัดลมต้องผ่านทรานซิสเตอร์ + มีไดโอดคร่อม (กันไฟย้อน)          **
   ============================================================ */

#define FAN_PIN 10        // ขาที่ไปเข้าขา B ของทรานซิสเตอร์ (ผ่าน R 1k)


void setup() {
  Serial.begin(115200);
  pinMode(FAN_PIN, OUTPUT);
  delay(500);
  Serial.println("STEP 7: ทดสอบพัดลม (เปิด 3 วิ / ปิด 3 วิ)");
}

void loop() {
  Serial.println("พัดลม: เปิด");
  digitalWrite(FAN_PIN, HIGH);     // ส่งไฟไปที่ขา B --> ทรานซิสเตอร์ "ปิดวงจร" --> พัดลมหมุน
  delay(3000);

  Serial.println("พัดลม: ปิด");
  digitalWrite(FAN_PIN, LOW);      // ตัดไฟขา B --> ทรานซิสเตอร์ "เปิดวงจร" --> พัดลมหยุด
  delay(3000);
}

/* ------------------------------------------------------------
   ผลที่ควรได้: พัดลมหมุน 3 วิ หยุด 3 วิ สลับกัน

   ถ้าพัดลมไม่หมุน ให้ไล่เช็ก:
   - ทรานซิสเตอร์เสียบถูกขาไหม? (ขา C-B-E สลับกันบ่อยมาก)
   - ตัวต้านทาน 1k อยู่ระหว่าง GPIO10 กับขา B หรือเปล่า?
   - พัดลมได้ไฟ 5V (VIN) ไม่ใช่ 3.3V ใช่ไหม?
   - GND ของพัดลมกับ GND ของบอร์ด ต้องเชื่อมถึงกัน!

   คำถาม 1: ทำไมพัดลมต่อกับ GPIO ตรง ๆ ไม่ได้? (คำใบ้: GPIO จ่ายได้ ~20mA
            แต่พัดลมกินเป็นร้อย mA)
   คำถาม 2: ไดโอดที่คร่อมพัดลมมีไว้ทำไม? (คำใบ้: ตอนพัดลมหยุด ขดลวดจะคาย
            ไฟย้อนกลับมา อาจพังทรานซิสเตอร์ได้)
   คำถาม 3: ในโปรเจกต์จริง เราจะเปิดพัดลมตอนไหน? ทำไมกล่องปิดถึงต้องมีพัดลม?
   ------------------------------------------------------------ */
